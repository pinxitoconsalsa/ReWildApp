generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?
  name          String
  avatarUrl     String?
  provider      String    @default("email") // email | google | apple
  providerId    String?
  xp            Int       @default(0)
  rank          String    @default("Semilla")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  trees           Tree[]
  posts           CommunityPost[]
  eventJoins      EventJoin[]
  nftCerts        NFTCertificate[]
  carbonLogs      CarbonCalcLog[]
  coursePurchases CoursePurchase[]
}

model Tree {
  id          String   @id @default(uuid())
  userId      String
  name        String
  scientificName String
  status      String   @default("SALUDABLE") // SALUDABLE | EN_RIESGO | MUERTO
  locationName String
  lat         Float
  lng         Float
  co2PerYear  Float    @default(0.2)
  photoUrl    String?
  plantedAt   DateTime @default(now())
  nftCert     NFTCertificate?
  user        User     @relation(fields: [userId], references: [id])
}

model ImpactMetric {
  id           String   @id @default(uuid())
  totalTrees   Int      @default(0)
  totalCO2Kg   Float    @default(0)
  totalSites   Int      @default(0)
  totalCommunities Int  @default(0)
  updatedAt    DateTime @updatedAt
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String   // Reforestacion | HuellaCarbono | Biodiversidad
  price       Float    @default(0)
  rating      Float    @default(4.9)
  reviewCount Int      @default(0)
  level       String   @default("PRINCIPIANTE")
  imageUrl    String?
  createdAt   DateTime @default(now())
  purchases   CoursePurchase[]
}

model CoursePurchase {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
  @@unique([userId, courseId])
}

model CommunityPost {
  id          String   @id @default(uuid())
  userId      String
  type        String   @default("USER") // USER | NEWS
  category    String   @default("GENERAL") // REFORESTACION | NOTICIAS | MI_BOSQUE
  title       String?
  content     String
  imageUrl    String?
  likes       Int      @default(0)
  comments    Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Event {
  id           String   @id @default(uuid())
  title        String
  description  String
  category     String   @default("Reforestacion")
  date         DateTime
  location     String
  totalSpots   Int
  joinedSpots  Int      @default(0)
  price        Float    @default(0)
  isFeatured   Boolean  @default(false)
  imageUrl     String?
  createdAt    DateTime @default(now())
  joins        EventJoin[]

  status String @default("OPEN") // OPEN | COMPLETO
}

model EventJoin {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
  @@unique([userId, eventId])
}

model NFTCertificate {
  id          String   @id @default(uuid())
  userId      String
  treeId      String   @unique
  tokenId     String   @unique
  lat         Float
  lng         Float
  co2PerYear  Float
  txHash      String?
  chain       String   @default("polygon")
  mintedAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  tree        Tree     @relation(fields: [treeId], references: [id])
}

model CarbonCalcLog {
  id           String   @id @default(uuid())
  userId       String?
  transport    Float
  diet         Float
  hogar        Float
  totalTonnes  Float
  treesNeeded  Int
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])
}

model MapProject {
  id           String   @id @default(uuid())
  name         String
  region       String
  country      String
  lat          Float
  lng          Float
  treesPlanted Int      @default(0)
  jobsCreated  Int      @default(0)
  communities  Int      @default(0)
  description  String?
  imageUrl     String?
  isActive     Boolean  @default(true)
}
